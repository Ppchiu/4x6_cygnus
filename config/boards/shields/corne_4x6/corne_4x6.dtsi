#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
	zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>; // 6 cols left + 6 cols right
        rows = <5>;     // 4 finger rows + 1 thumb row
        
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)      RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)      RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)      RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)      RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                                    RC(4,3) RC(4,4) RC(4,5)      RC(4,6) RC(4,7) RC(4,8)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;

        col-gpios
            = <&pro_micro 21 GPIO_ACTIVE_HIGH>
            , <&pro_micro 20 GPIO_ACTIVE_HIGH>
            , <&pro_micro 19 GPIO_ACTIVE_HIGH>
            , <&pro_micro 18 GPIO_ACTIVE_HIGH>
            , <&pro_micro 15 GPIO_ACTIVE_HIGH>
            , <&pro_micro 14 GPIO_ACTIVE_HIGH>;
    };
    physical_layout0: physical_layout_0 {
    compatible = "zmk,physical-layout";
    display-name = "Corne 4x6 Custom";

    // Each key: width, height, x, y, rotation, rx, ry
    keys =
        // LEFT HALF - Row 0 (Numbers)
        < &key_physical_attrs 100 100    0  25 0 0 0 >
        , < &key_physical_attrs 100 100  100  25 0 0 0 >
        , < &key_physical_attrs 100 100  200   0 0 0 0 >
        , < &key_physical_attrs 100 100  300  25 0 0 0 >
        , < &key_physical_attrs 100 100  400  50 0 0 0 >
        , < &key_physical_attrs 100 100  500  50 0 0 0 >

        // RIGHT HALF - Row 0 (Numbers)
        , < &key_physical_attrs 100 100  800  50 0 0 0 >
        , < &key_physical_attrs 100 100  900  50 0 0 0 >
        , < &key_physical_attrs 100 100 1000  25 0 0 0 >
        , < &key_physical_attrs 100 100 1100   0 0 0 0 >
        , < &key_physical_attrs 100 100 1200  25 0 0 0 >
        , < &key_physical_attrs 100 100 1300  25 0 0 0 >

        // LEFT HALF - Row 1 (Top Alpha)
        , < &key_physical_attrs 100 100    0 125 0 0 0 >
        , < &key_physical_attrs 100 100  100 125 0 0 0 >
        , < &key_physical_attrs 100 100  200 100 0 0 0 >
        , < &key_physical_attrs 100 100  300 125 0 0 0 >
        , < &key_physical_attrs 100 100  400 150 0 0 0 >
        , < &key_physical_attrs 100 100  500 150 0 0 0 >

        // RIGHT HALF - Row 1 (Top Alpha)
        , < &key_physical_attrs 100 100  800 150 0 0 0 >
        , < &key_physical_attrs 100 100  900 150 0 0 0 >
        , < &key_physical_attrs 100 100 1000 125 0 0 0 >
        , < &key_physical_attrs 100 100 1100 100 0 0 0 >
        , < &key_physical_attrs 100 100 1200 125 0 0 0 >
        , < &key_physical_attrs 100 100 1300 125 0 0 0 >

        // LEFT HALF - Row 2 (Home Row)
        , < &key_physical_attrs 100 100    0 225 0 0 0 >
        , < &key_physical_attrs 100 100  100 225 0 0 0 >
        , < &key_physical_attrs 100 100  200 200 0 0 0 >
        , < &key_physical_attrs 100 100  300 225 0 0 0 >
        , < &key_physical_attrs 100 100  400 250 0 0 0 >
        , < &key_physical_attrs 100 100  500 250 0 0 0 >

        // RIGHT HALF - Row 2 (Home Row)
        , < &key_physical_attrs 100 100  800 250 0 0 0 >
        , < &key_physical_attrs 100 100  900 250 0 0 0 >
        , < &key_physical_attrs 100 100 1000 225 0 0 0 >
        , < &key_physical_attrs 100 100 1100 200 0 0 0 >
        , < &key_physical_attrs 100 100 1200 225 0 0 0 >
        , < &key_physical_attrs 100 100 1300 225 0 0 0 >

        // LEFT HALF - Row 3 (Bottom Alpha)
        , < &key_physical_attrs 100 100    0 325 0 0 0 >
        , < &key_physical_attrs 100 100  100 325 0 0 0 >
        , < &key_physical_attrs 100 100  200 300 0 0 0 >
        , < &key_physical_attrs 100 100  300 325 0 0 0 >
        , < &key_physical_attrs 100 100  400 350 0 0 0 >
        , < &key_physical_attrs 100 100  500 350 0 0 0 >

        // RIGHT HALF - Row 3 (Bottom Alpha)
        , < &key_physical_attrs 100 100  800 350 0 0 0 >
        , < &key_physical_attrs 100 100  900 350 0 0 0 >
        , < &key_physical_attrs 100 100 1000 325 0 0 0 >
        , < &key_physical_attrs 100 100 1100 300 0 0 0 >
        , < &key_physical_attrs 100 100 1200 325 0 0 0 >
        , < &key_physical_attrs 100 100 1300 325 0 0 0 >

        // LEFT HALF - Thumb Cluster (Angled slightly)
        , < &key_physical_attrs 100 100  400 475 15 450 525 >
        , < &key_physical_attrs 100 100  500 450 0 0 0 >
        , < &key_physical_attrs 100 100  600 425 0 0 0 >

        // RIGHT HALF - Thumb Cluster (Angled slightly)
        , < &key_physical_attrs 100 100  700 425 0 0 0 >
        , < &key_physical_attrs 100 100  800 450 0 0 0 >
        , < &key_physical_attrs 100 100  900 475 -15 850 525 >
        ;
    };
};
